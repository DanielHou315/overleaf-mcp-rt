# Copy to .env.integration (gitignored) and fill in real values for local
# integration testing against a live Overleaf Community Edition instance.
#
# Usage:
#   set -a; source .env.integration; set +a
#   RUN_INTEGRATION=1 npm run test:integration
#
# These variables are consumed by test/integration/ce-fixture.test.ts.

TEST_OVERLEAF_URL=http://your-overleaf-host:port
TEST_OVERLEAF_EMAIL=you@example.com
TEST_OVERLEAF_PASSWORD=your-password
