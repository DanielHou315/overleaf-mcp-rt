{
  "name": "overleaf-mcp",
  "version": "0.1.0",
  "description": "MCP server for Overleaf Community Edition without git",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "bin": {
    "overleaf-mcp": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "test:integration": "RUN_INTEGRATION=1 vitest run --config vitest.integration.config.ts",
    "start": "node dist/cli.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "fast-diff": "^1.3.0",
    "node-html-parser": "^7.0.0",
    "socket.io-client": "github:overleaf/socket.io-client#0.9.17-overleaf-5"
  },
  "devDependencies": {
    "@types/fast-diff": "^1.2.2",
    "@types/node": "^20.0.0",
    "msw": "^2.4.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
